{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://n-framework.dev/schemas/nfw/template.schema.json",
  "title": "NFW Template Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "description", "version"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional JSON schema pointer for YAML tooling."
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9/]+(?:-[a-z0-9/]+)*$",
      "description": "Template identifier in kebab-case (allows slashes)."
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
      "description": "SemVer version string."
    },
    "language": {
      "type": "string",
      "enum": ["csharp", "go", "rust", "neutral"],
      "description": "Optional. Omit for language-agnostic templates."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "default": []
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "min_cli_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "source_url": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/template_input" },
      "description": "Optional input parameters for the template.",
      "default": []
    },
    "required_modules": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Modules that must be present in the target service before this template can execute.",
      "default": []
    },
    "generators": {
      "type": "object",
      "properties": {
        "service": { "type": "string" },
        "persistence": { "type": "string" },
        "api": { "type": "string" },
        "command": { "type": "string" },
        "mediator": { "type": "string" },
        "query": { "type": "string" }
      },
      "additionalProperties": false,
      "description": "Explicit path mappings for child generators (e.g. service, persistence)."
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action"],
        "properties": {
          "action": {
            "type": "string",
            "enum": ["render", "render_folder", "inject", "run_command"]
          },
          "source": { "type": "string" },
          "destination": { "type": "string" },
          "command": {
            "type": "string",
            "description": "Required for run_command action. The command to execute."
          },
          "working_directory": {
            "type": "string",
            "description": "Optional for run_command action. Directory to run the command in."
          },
          "injection_target": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string", "enum": ["at_end", "region", "pattern_region"] },
              "value": { "type": "string" },
              "start_pattern": { "type": "string" },
              "end_pattern": { "type": "string" }
            },
            "if": {
              "properties": { "type": { "const": "region" } }
            },
            "then": {
              "required": ["value"]
            },
            "else": {
              "if": {
                "properties": { "type": { "const": "pattern_region" } }
              },
              "then": {
                "required": ["start_pattern", "end_pattern"]
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "template_input": {
      "type": "object",
      "required": ["id", "type", "prompt"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_\\-./]+$",
          "description": "Unique identifier for the input variable."
        },
        "type": {
          "type": "string",
          "enum": ["text", "password", "confirm", "select", "multiselect", "object", "list"],
          "description": "Input type."
        },
        "prompt": {
          "type": "string",
          "description": "Message displayed to the user when prompted."
        },
        "description": {
          "type": "string",
          "description": "Optional description displayed below the prompt."
        },
        "default": {
          "description": "Optional default value."
        },
        "options": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Valid choices for select/multiselect types."
        },
        "properties": {
          "type": "array",
          "items": { "$ref": "#/$defs/template_input" },
          "description": "Nested properties for 'object' type inputs."
        },
        "items": {
          "$ref": "#/$defs/template_input",
          "description": "Element schema for 'list' type inputs."
        }
      }
    }
  }
}
