<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFramework>net11.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
	</PropertyGroup>
	<!-- Project References -->
	<ItemGroup>
		<ProjectReference Include="../../core/{{ Name }}.Core.Application/{{ Name }}.Core.Application.csproj" />
		<ProjectReference Include="../../core/{{ Name }}.Core.Domain/{{ Name }}.Core.Domain.csproj" />
	</ItemGroup>
	<!-- Package References -->
	<ItemGroup>
		<PackageReference Include="Microsoft.EntityFrameworkCore.InMemory" Version="10.0.5" />
		<PackageReference Include="Microsoft.Extensions.Configuration.Binder" Version="10.0.5" />
		<PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.5" />
	</ItemGroup>
</Project>
